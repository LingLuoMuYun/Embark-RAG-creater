generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model KnowledgeBase {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  icon        String? @default("")
  chunkSize           Int   @default(800)
  chunkOverlap        Int   @default(100)
  similarityThreshold Float @default(0.7)
  topK                Int   @default(5)
  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents KnowledgeDocument[]
  chunks    KnowledgeChunk[]

  @@index([status])
}

model KnowledgeDocument {
  id              String @id @default(cuid())
  knowledgeBaseId String

  title      String
  sourceType String @default("manual")

  fileName String?
  fileUrl  String?
  mimeType String?
  fileSize Int?

  rawContent String?
  parseStatus String @default("pending")
  status String @default("active")
  error String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeBase KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([knowledgeBaseId])
  @@index([parseStatus])
  @@index([status])
}

model KnowledgeChunk {
  id              String @id @default(cuid())
  knowledgeBaseId String
  documentId      String

  content   String
  chunkIndex Int
  embedding String?

  status String @default("active")

  startIndex Int?
  endIndex   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeBase KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document      KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([documentId])
  @@index([status])
  @@index([knowledgeBaseId, status])
}

model DocumentSource {
  id           String          @id @default(cuid())
  originalName String
  fileType     String
  fileSize     Int
  status       String          @default("uploading")
  content      String?
  errorMessage String?
  chunkCount   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  chunks       DocumentChunk[]

  @@index([status])
}

model DocumentChunk {
  id               String         @id @default(cuid())
  documentSourceId String
  chunkIndex       Int
  content          String
  charStart        Int
  charEnd          Int
  createdAt        DateTime       @default(now())
  documentSource   DocumentSource @relation(fields: [documentSourceId], references: [id], onDelete: Cascade)

  @@index([documentSourceId])
  @@index([documentSourceId, chunkIndex])
}

model ExpertAgent {
  id          String  @id @default(cuid())
  name        String
  description String?

  /// Answer style key, for example: strict, concise, teaching, support.
  answerStyle String @default("strict")

  /// JSON string for flexible scope configuration before retrieval tables settle.
  /// Expected shape can map to RagRetrieveRequest.scope:
  /// {
  ///   "mode": "all" | "knowledgeBases" | "categories" | "tags" | "knowledgeItems",
  ///   "knowledgeBaseIds": string[],
  ///   "categoryIds": string[],
  ///   "tagIds": string[],
  ///   "knowledgeIds": string[],
  ///   "chunkTypes": string[]
  /// }
  knowledgeScope String @default("{}")

  showReferences        Boolean @default(true)
  allowKnowledgeCapture Boolean @default(false)

  /// Agent lifecycle status. Keep as String to avoid enum churn in team integration.
  /// Suggested values: draft, active, disabled.
  status String @default("draft")

  systemPrompt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([answerStyle])
  @@index([createdAt])
}
