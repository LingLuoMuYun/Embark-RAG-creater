generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}
model KnowledgeBase {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  icon  String @default("Database")
  color String @default("blue")

  similarityThreshold Float @default(0.7)
  topK                Int   @default(5)

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents KnowledgeBaseDocument[]

  @@index([status])
}
model KnowledgeDocument {
  id    String @id @default(cuid())
  title String

  sourceType String @default("manual")

  fileName String?
  fileUrl  String?
  mimeType String?
  fileSize Int?

  rawContent String?

  chunkSize    Int @default(800)
  chunkOverlap Int @default(100)

  parseStatus String @default("pending")
  status      String @default("active")
  error       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeBases KnowledgeBaseDocument[]
  chunks         KnowledgeChunk[]

  @@index([sourceType])
  @@index([parseStatus])
  @@index([status])
}

model KnowledgeBaseDocument {
  id              String @id @default(cuid())
  knowledgeBaseId String
  documentId      String

  status    String @default("active")
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  knowledgeBase KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document      KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBaseId, documentId])
  @@index([knowledgeBaseId])
  @@index([documentId])
  @@index([status])
}


model KnowledgeChunk {
  id         String @id @default(cuid())
  documentId String

  content    String
  chunkIndex Int

  embedding String?

  status String @default("active")

  startIndex Int?
  endIndex   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@index([documentId, status])
}

model DocumentSource {
  id           String          @id @default(cuid())
  originalName String
  fileType     String
  fileSize     Int
  status       String          @default("uploading")
  content      String?
  errorMessage String?
  chunkCount   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  chunks       DocumentChunk[]

  @@index([status])
}

model DocumentChunk {
  id               String         @id @default(cuid())
  documentSourceId String
  chunkIndex       Int
  content          String
  charStart        Int
  charEnd          Int
  createdAt        DateTime       @default(now())
  documentSource   DocumentSource @relation(fields: [documentSourceId], references: [id], onDelete: Cascade)

  @@index([documentSourceId])
  @@index([documentSourceId, chunkIndex])
}

model CandidateKnowledge {
  id                String   @id @default(cuid())
  documentSourceId  String?
  title             String
  content           String
  suggestedCategory String?
  suggestedTags     String?
  type              String   @default("concept")
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([documentSourceId])
}
